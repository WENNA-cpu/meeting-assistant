DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# faster-whisper（备选）：使用模型名称 base，通过国内镜像下载
HF_ENDPOINT=https://hf-mirror.com
WHISPER_MODEL=base
WHISPER_CACHE_DIR=E:/AiMeetWise/backend/models/faster-whisper

# FFmpeg whisper（优先）：使用 ggml-base.bin
WHISPER_MODEL_DIR=E:/AiMeetWise/backend/models/whisper.cpp
# WHISPER_MODEL_PATH=E:/AiMeetWise/backend/models/whisper.cpp/ggml-base.bin
FFMPEG_PATH=C:\Users\Admin\ffmpeg\bin\ffmpeg.exe

# Whisper 转写提示词，引导输出简体中文
WHISPER_INITIAL_PROMPT=以下是普通话会议录音，请使用简体中文输出。

# 设为 true 时强制使用 Mock 转写（调试用）
# MOCK_TRANSCRIPTION=false
